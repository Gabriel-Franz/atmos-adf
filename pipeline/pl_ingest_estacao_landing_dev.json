{
	"name": "pl_ingest_estacao_landing_dev",
	"properties": {
		"activities": [
			{
				"name": "copy_inmet_to_landing",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "GoogleBigQueryV2Source"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_bigquery_estacao_src_dev",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ds_csv_estacao_landing_dev",
						"type": "DatasetReference",
						"parameters": {
							"file_name": "@concat('estacao_',formatDateTime(utcNow(),'yyyyMMddHHmmss'),'.csv')"
						}
					}
				]
			}
		],
		"folder": {
			"name": "INMET"
		},
		"annotations": []
	}
}